# ── 프로파일 ──────────────────────────────────────────────────────────
# local: 내 PC docker-compose
# dev  : 팀 공유 개발 서버 / GCP VM 인프라
# prod : 운영 환경
SPRING_PROFILES_ACTIVE=local

# ── local 기본값 ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=goggles
DB_USERNAME=goggles
DB_PASSWORD=goggles

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

ZIPKIN_HOST=localhost

# ── dev 환경 예시 ────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# CONFIG_SERVER_URL=http://<CONFIG_SERVER_HOST>:9000
# DB_HOST=<POSTGRES_INTERNAL_IP>
# DB_PORT=5432
# DB_NAME=goggles
# DB_USERNAME=****
# DB_PASSWORD=****
# REDIS_HOST=<REDIS_INTERNAL_IP>
# REDIS_PORT=6379
# KAFKA_BOOTSTRAP_SERVERS=<KAFKA_INTERNAL_IP>:9092
# EUREKA_DEFAULT_ZONE=http://<EUREKA_VM_1_INTERNAL_IP>:9001/eureka/,http://<EUREKA_VM_2_INTERNAL_IP>:9002/eureka/
# MONITORING_HOST=<MONITORING_VM_EXTERNAL_IP>

# ── prod 환경 예시 ───────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=prod
# CONFIG_SERVER_URL=http://<CONFIG_SERVER_HOST>:9000
# REDIS_SENTINEL_1=<REDIS_1_INTERNAL_IP>:26379
# REDIS_SENTINEL_2=<REDIS_2_INTERNAL_IP>:26379
# REDIS_SENTINEL_3=<REDIS_3_INTERNAL_IP>:26379
# REDIS_PASSWORD=****