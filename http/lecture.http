### 변수 (필요 시 환경에 맞게 수정)
@host = localhost:9005
@instructorId = 11111111-1111-1111-1111-111111111111
@instructorName = 홍길동

### 1. 강의 생성 (DRAFT 상태로 생성됨)
POST http://{{host}}/api/v1/lectures
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "category": "IT",
  "title": "스프링 부트 마스터 클래스",
  "subtitle": "기초부터 실전까지",
  "description": "스프링 부트 3.x를 활용한 실전 백엔드 개발 강의입니다.",
  "durationPolicy": "DAYS_365",
  "price": 99000
}

> {%
    client.test("강의 생성 성공", function () {
        client.assert(response.status === 201, "응답 코드가 201이어야 합니다.");
        client.assert(response.body.data.id !== null, "id가 반환되어야 합니다.");
        client.assert(response.body.data.status === "DRAFT", "초기 상태는 DRAFT여야 합니다.");
        client.global.set("createdLectureId", response.body.data.id);
    });
%}

### 2. 강의 생성 - durationPolicy 생략 (도메인 기본값 DAYS_365 적용)
POST http://{{host}}/api/v1/lectures
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "category": "프로그래밍",
  "title": "자바 기초",
  "subtitle": "Hello World 부터 OOP 까지",
  "description": "프로그래밍 입문자를 위한 자바 강의",
  "price": 49000
}

### 3. 강의 생성 - 유효성 실패 (가격 누락)
POST http://{{host}}/api/v1/lectures
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "category": "IT",
  "title": "테스트 강의",
  "subtitle": "부제",
  "description": "설명"
}

> {%
    client.test("validation 실패", function () {
        client.assert(response.status === 400, "응답 코드가 400이어야 합니다.");
    });
%}

### 4. 강의 생성 - 유효성 실패 (카테고리 빈 문자열)
POST http://{{host}}/api/v1/lectures
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "category": "",
  "title": "테스트 강의",
  "subtitle": "부제",
  "description": "설명",
  "price": 10000
}

### 5. 강의 생성 - 헤더 누락 (X-User-Id 없음)
POST http://{{host}}/api/v1/lectures
Content-Type: application/json
X-User-Name: {{instructorName}}

{
  "category": "IT",
  "title": "테스트 강의",
  "subtitle": "부제",
  "description": "설명",
  "price": 10000
}

### 6. 강의 목록 조회 (기존)
GET http://{{host}}/api/v1/lectures?page=0&size=10

### 7. 강의 상세 조회 (기존, 위에서 생성한 것 - DRAFT라 404 예상)
GET http://{{host}}/api/v1/lectures/{{createdLectureId}}

### 8. 챕터 생성 - 성공
POST http://{{host}}/api/v1/lectures/{{createdLectureId}}/chapters
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "title": "1강. 강의 소개",
  "content": "스프링 부트 강의 소개 및 학습 목표를 설명합니다.",
  "sortOrder": 1,
  "durationSeconds": 600
}

> {%
    client.test("챕터 생성 성공", function () {
        client.assert(response.status === 201, "응답 코드가 201이어야 합니다.");
        client.assert(response.body.data.lectureId !== null, "lectureId가 반환되어야 합니다.");
        client.assert(response.body.data.chapterId !== null, "chapterId가 반환되어야 합니다.");
    });
%}

### 9. 챕터 생성 - 실패 (존재하지 않는 강의)
POST http://{{host}}/api/v1/lectures/00000000-0000-0000-0000-000000000000/chapters
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "title": "1강. 강의 소개",
  "content": "스프링 부트 강의 소개",
  "sortOrder": 1,
  "durationSeconds": 600
}

### 10. 챕터 생성 - 실패 (필수값 누락)
POST http://{{host}}/api/v1/lectures/{{createdLectureId}}/chapters
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "title": "",
  "content": "내용",
  "sortOrder": 1,
  "durationSeconds": 600
}

### 11. 챕터 생성 - 실패 (정렬 순서 중복)
POST http://{{host}}/api/v1/lectures/{{createdLectureId}}/chapters
Content-Type: application/json
X-User-Id: {{instructorId}}
X-User-Name: {{instructorName}}

{
  "title": "1강. 중복 챕터",
  "content": "sortOrder가 중복되는 챕터입니다.",
  "sortOrder": 1,
  "durationSeconds": 300
}